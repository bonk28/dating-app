@bp.route('/top-profiles')
@login_required
def top_profiles():
    # Profils avec le plus de likes cette semaine
    from datetime import timedelta
    week_ago = datetime.utcnow() - timedelta(days=7)
    
    top = User.query.filter(
        User.id != current_user.id,
        User.is_active == True
    ).order_by(User.last_seen.desc()).limit(10).all()
    
    return render_template('top_profiles.html', users=top)

@bp.route('/my-stats')
@login_required
def my_stats():
    from datetime import timedelta
    
    stats = {
        'total_likes_sent': Like.query.filter_by(liker_id=current_user.id).count(),
        'total_likes_received': Like.query.filter_by(liked_id=current_user.id).count(),
        'total_matches': Match.query.filter(
            (Match.user1_id == current_user.id) | (Match.user2_id == current_user.id)
        ).count(),
        'total_messages': Message.query.filter_by(sender_id=current_user.id).count(),
        'swipes_today': Like.query.filter_by(
            liker_id=current_user.id
        ).filter(
            Like.created_at >= datetime.now().date()
        ).count(),
        'profile_views': 42  # fictif
    }
    
    return render_template('my_stats.html', stats=stats)


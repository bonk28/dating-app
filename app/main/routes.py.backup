@bp.route('/music-match/<int:match_id>')
@login_required
def music_match(match_id):
    """Voir les goûts musicaux communs"""
    match = Match.query.get_or_404(match_id)
    other_id = match.user2_id if match.user1_id == current_user.id else match.user1_id
    other_user = User.query.get(other_id)
    
    return render_template('music_match.html', other_user=other_user, match=match)


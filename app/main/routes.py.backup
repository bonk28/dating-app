@bp.route('/profile/<int:user_id>')
@login_required
def view_profile(user_id):
    """Voir le profil d'un autre utilisateur"""
    user = User.query.get_or_404(user_id)
    
    # Ne pas voir son propre profil (rediriger vers /profile)
    if user.id == current_user.id:
        return redirect(url_for('main.profile'))
    
    # Calculer la compatibilité
    compatibility = current_user.get_compatibility(user)
    
    # Calculer la distance si possible
    distance = None
    if current_user.latitude and current_user.longitude and user.latitude and user.longitude:
        from math import radians, sin, cos, sqrt, atan2
        lat1, lon1 = radians(current_user.latitude), radians(current_user.longitude)
        lat2, lon2 = radians(user.latitude), radians(user.longitude)
        dlat, dlon = lat2 - lat1, lon2 - lon1
        a = sin(dlat/2)**2 + cos(lat1) * cos(lat2) * sin(dlon/2)**2
        c = 2 * atan2(sqrt(a), sqrt(1-a))
        distance = int(6371 * c)
    
    # Récupérer les photos de l'utilisateur
    photos = UserPhoto.query.filter_by(user_id=user.id).all()
    
    # Vérifier si on a déjà liké cette personne
    existing_like = Like.query.filter_by(
        liker_id=current_user.id, 
        liked_id=user.id
    ).first()
    
    return render_template('view_profile.html', 
                         user=user, 
                         compatibility=compatibility,
                         distance=distance,
                         photos=photos,
                         existing_like=existing_like)

